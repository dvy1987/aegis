{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.local/schemas/case.schema.json",
  "x-aegis-schema-version": "1.1.0",
  "title": "Aegis Synthetic Denial Case",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id",
    "insurer",
    "denial_type",
    "patient_profile",
    "denial_pattern_sources",
    "denial_letter_text",
    "clinical_context",
    "synthetic_provenance"
  ],
  "properties": {
    "case_id": {
      "type": "string",
      "pattern": "^case_[0-9]{2,4}_(aetna|cigna|uhc)_(mednec|priorauth)$",
      "description": "case_<NN>_<insurer-lower>_<short-denial-type>; mednec = Medical Necessity, priorauth = Prior Authorization."
    },
    "insurer": {"type": "string", "enum": ["Aetna", "Cigna", "UHC"]},
    "denial_type": {
      "type": "string",
      "enum": ["Medical Necessity", "Prior Authorization"]
    },
    "patient_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["age", "gender", "diagnosis", "treatment_requested", "plan_funding_type"],
      "properties": {
        "age": {"type": "integer", "minimum": 18, "maximum": 89},
        "gender": {"type": "string", "enum": ["M", "F", "nonbinary"]},
        "diagnosis": {"type": "string", "minLength": 6, "maxLength": 240},
        "treatment_requested": {"type": "string", "minLength": 6, "maxLength": 240},
        "plan_funding_type": {"type": "string", "enum": ["fully_insured", "self_funded"]}
      }
    },
    "denial_pattern_sources": {
      "type": "array",
      "items": { "type": "string", "minLength": 8 },
      "minItems": 1,
      "description": "P4 output: each entry SHOULD start with a denial_patterns.json pattern id (e.g. 'missing_iro_notice: <source citation>')."
    },
    "denial_letter_text": {
      "type": "string",
      "minLength": 1000,
      "maxLength": 3200,
      "description": "P2: insurer-voice denial letter, roughly 200-500 words (not character-count gaming)."
    },
    "clinical_context": {
      "type": "string",
      "minLength": 400,
      "maxLength": 1600,
      "description": "P3: rebuttal-specific clinical narrative, roughly 80-250 words, must contradict the denial."
    },
    "submission_timestamp": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "denial_timestamp": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "synthetic_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generator_model",
        "run_id",
        "generated_at",
        "matrix_cell",
        "prompt_versions",
        "banned_topic_filter_version",
        "schema_version",
        "diversity_matrix_version",
        "human_summary",
        "appeal_difficulty",
        "critic_verdicts"
      ],
      "properties": {
        "generator_model": {"type": "string"},
        "run_id": {"type": "string"},
        "generated_at": {"type": "string", "format": "date-time"},
        "matrix_cell": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "insurer",
            "denial_type",
            "specialty",
            "patient_age_band",
            "patient_gender",
            "sub_tactic"
          ],
          "properties": {
            "insurer": {"type": "string"},
            "denial_type": {"type": "string"},
            "specialty": {"type": "string"},
            "patient_age_band": {"type": "string"},
            "patient_gender": {"type": "string"},
            "sub_tactic": {"type": "string"}
          }
        },
        "prompt_versions": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        },
        "banned_topic_filter_version": {"type": "string"},
        "schema_version": {"type": "string"},
        "diversity_matrix_version": {"type": "string"},
        "critic_verdicts": {
          "type": "object",
          "additionalProperties": true,
          "description": "Per-stage independent critic outputs captured for AlphaEval auditability."
        },
        "human_summary": {"type": "string"},
        "appeal_difficulty": {
          "type": "object",
          "additionalProperties": false,
          "required": ["score", "reasoning", "exploitable_weaknesses", "strong_defenses"],
          "properties": {
            "score": { "type": "integer", "minimum": 1, "maximum": 5 },
            "reasoning": { "type": "string", "minLength": 40 },
            "exploitable_weaknesses": {
              "type": "array",
              "items": { "type": "string", "minLength": 12 },
              "minItems": 1
            },
            "strong_defenses": {
              "type": "array",
              "items": { "type": "string", "minLength": 12 },
              "minItems": 1
            }
          },
          "description": "Teacher-only. Never passed to the appeal agent or Phoenix student traces."
        },
        "evaluator_disagreements": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "dimension": { "type": "string" },
              "internal_verdict": { "type": "string" },
              "gumloop_verdict": { "type": "string" },
              "resolution": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
