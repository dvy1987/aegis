# Copy to .env and fill in. .env is gitignored.

# Google Cloud / Vertex AI
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Arize Phoenix Cloud
PHOENIX_API_KEY=your-phoenix-api-key
PHOENIX_HOST=https://app.phoenix.arize.com
# PHOENIX_PROJECT_NAME is set per-process by dev.sh (both use aegis-hackathon).
# Only uncomment if you need a different project when running a backend directly.
# PHOENIX_PROJECT_NAME=aegis-hackathon

# Vertex AI Search (cloud library — enable at demo; no local corpus fallback in v1)
# VERTEX_SEARCH_PROJECT=your-gcp-project
# VERTEX_SEARCH_LOCATION=global
# VERTEX_SEARCH_DATA_STORE_ID=your-data-store-id
# VERTEX_SEARCH_SERVING_CONFIG=default_config

# GCS bucket for library documents (ingest script --upload only)
# AEGIS_LIBRARY_BUCKET=your-aegis-library-bucket

# App config
APP_ENV=local
LOG_LEVEL=INFO
